    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.2.3",
    "vue-tsc": "^2.2.8"
  }
}
