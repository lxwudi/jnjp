{
  "name": "campus-switch-agent-console",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "tsc -p tsconfig.server.json && node server/dist/index.js",
    "server:dev": "tsx watch server/src/index.ts",
